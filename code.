import os
import openai
import json
from datetime import datetime

openai.api_key = "YOUR_API_KEY"

# ---- Memory ----
chat_history = []

# ---- Tools ----
def get_time():
    return str(datetime.now())

def calculate(expression):
    try:
        return str(eval(expression))
    except:
        return "Error in calculation"

TOOLS = {
    "get_time": get_time,
    "calculate": calculate
}

# ---- Agent Brain ----
def agent_response(user_input):
    global chat_history
    
    messages = [
        {"role": "system", "content": 
         "You are a smart AI assistant. Talk like a human. Be helpful and concise. "
         "If needed, call tools to complete tasks."}
    ] + chat_history + [{"role": "user", "content": user_input}]
    
    response = openai.ChatCompletion.create(
        model="gpt-4o-mini",
        messages=messages,
        functions=[
            {
                "name": "get_time",
                "description": "Get current time",
                "parameters": {}
            },
            {
                "name": "calculate",
                "description": "Solve math expressions",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "expression": {"type": "string"}
                    }
                }
            }
        ],
        function_call="auto"
    )
    
    msg = response["choices"][0]["message"]

    # ---- Tool Call ----
    if msg.get("function_call"):
        func_name = msg["function_call"]["name"]
        args = json.loads(msg["function_call"].get("arguments", "{}"))
        
        result = TOOLS[func_name](**args)
        
        chat_history.append(msg)
        chat_history.append({
            "role": "function",
            "name": func_name,
            "content": result
        })
        
        return f"[Tool Used: {func_name}] → {result}"
    
    chat_history.append({"role": "user", "content": user_input})
    chat_history.append({"role": "assistant", "content": msg["content"]})
    
    return msg["content"]


# ---- Run Loop ----
while True:
    user_input = input("You: ")
    if user_input.lower() in ["exit", "quit"]:
        break
    
    reply = agent_response(user_input)
    print("AI:", reply)